```elixir
Application.put_env(:atp_client, :local_exec, [binary: "eprover-ho"])

Application.put_env(:atp_client, :starexec, [
  base_url: "https://127.0.0.1:7827",
  username: "admin",
  password: "admin",
  space_id: 1,
  solver_cfg_id: 1,
  connect_options: [transport_opts: [verify: :verify_none]]
])

```

<!-- livebook:{"attrs":"","chunks":null,"kind":"Elixir.KinoAtpClient.AtpSolver","livebook_object":"smart_cell"} -->

```elixir
# Generated by ATP Solver (backend: SystemOnTPTP)
problem = "thf(conj, conjecture,\n  ![H: $o>$i]: ((H @ ((H @ $true) = (H @ $false))) = (H @ $false))\n)."
system = "Leo-III---1.8.0"
time_limit = 5

case AtpClient.SystemOnTptp.query_system(problem, system, time_limit_sec: time_limit, raw: true) do
  {:ok, output} ->
    IO.puts(output)
    output

  {:error, reason} ->
    raise "SystemOnTPTP error: #{inspect(reason)}"
end

```

Example problems:

* $h~(h~\top = h~\bot) = h~\bot$
* $(\forall X.\,\exists Y.\,r~X~Y) \supset (\exists F.\,\forall X.\,r~X~(F~X))$

## Teardown the Isabelle server

```elixir
IsabelleClient.Server.kill(server.name)
```
